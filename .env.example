# =============================================
# MarkFace Hub - Environment Variables Example
# Copy this file to .env and fill in the values
# =============================================

# ─── Application ─────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-very-long-random-secret-key

# ─── JWT ─────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-different-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ───────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=markface
POSTGRES_USER=markface
POSTGRES_PASSWORD=markface_secret
DATABASE_URL=postgresql+asyncpg://markface:markface_secret@postgres:5432/markface

# ─── Redis ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ─── Celery ──────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Seed / Bootstrap ────────────────────────
ADMIN_EMAIL=admin@markface.com
ADMIN_PASSWORD=Admin@1234

# ─── WooCommerce Webhooks ─────────────────────
# Generate in WooCommerce → Settings → Advanced → Webhooks
WOO_WEBHOOK_SECRET=your_woo_webhook_secret_here
WOO_WEBHOOK_TOLERANCE_SECONDS=300
WOO_SKU_FIELD=sku
