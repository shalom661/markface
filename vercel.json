{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "frontend/dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api|assets|favicon.ico|logo.png|LOGO-sem-pijamas).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/health-check",
            "schedule": "0 */2 * * *"
        }
    ]
}