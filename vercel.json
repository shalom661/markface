{
    "version": 2,
    "functions": {
        "api/*.py": {
            "runtime": "@vercel/python"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api|assets|favicon.ico|logo.png|LOGO-sem-pijamas).*)",
            "destination": "/index.html"
        }
    ]
}